# Backend API Base URL (defaults to http://localhost:8001 for local development)
# For production: use your Render backend URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Google Gemini AI API Key for flood analysis (preferred)
GEMINI_API_KEY=your_google_ai_api_key_here

# Backward compatibility (optional fallback if GEMINI_API_KEY not set)
# GOOGLE_API_KEY=your_google_ai_api_key_here

# Google Maps API Key for interactive map (optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

